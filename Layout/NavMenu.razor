@using quiz_project.Services
@inject AuthService auth
@inject NavigationManager nav

<nav class="sidebar">

    <div class="logo">
        💰 FinQuiz
    </div>

    @if (!string.IsNullOrEmpty(auth.CurrentUser))
    {
        <div class="username">
            👤 @auth.CurrentUser
        </div>
    }

    <NavLink href="/dashboard" class="nav-link">
        🏠 Dashboard
    </NavLink>

    <NavLink href="/quiz/Savings" class="nav-link">
        🧠 Quiz
    </NavLink>

    <NavLink href="/leaderboard" class="nav-link">
        🏆 Leaderboard
    </NavLink>

    <NavLink href="/rewards" class="nav-link">
        🎁 Rewards
    </NavLink>

   
      
    
    
        <NavLink href="/login" class="nav-link">
            🔐 Login
        </NavLink>

        <NavLink href="/signup" class="nav-link">
            ✍ Signup
        </NavLink>
    <button class="logout-btn" @onclick="() => Logout()">
        🚪 Logout
    </button>
    

</nav>


<style>

    /* Sidebar container */

    .sidebar {
        height: 100vh;
        width: 240px;
        background: linear-gradient(180deg,#0f2027,#203a43,#2c5364);
        padding: 30px 20px;
        display: flex;
        flex-direction: column;
        animation: slideIn 0.7s ease;
    }

    /* Logo */

    .logo {
        font-size: 26px;
        font-weight: bold;
        color: white;
        margin-bottom: 10px;
    }

    /* Username display */

    .username {
        color: #ffd166;
        font-size: 15px;
        margin-bottom: 25px;
    }

    /* Navigation links */

    .nav-link {
        color: white;
        text-decoration: none;
        font-size: 17px;
        padding: 12px 16px;
        border-radius: 10px;
        margin-bottom: 10px;
        transition: 0.3s ease;
    }

        /* Hover effect */

        .nav-link:hover {
            background: rgba(255,255,255,0.18);
            transform: translateX(6px);
        }

        /* Active link highlight */

        .nav-link.active {
            background: white;
            color: #203a43;
            font-weight: bold;
        }

    /* Logout button */

    .logout-btn {
        margin-top: auto;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: #ff6b6b;
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s ease;
    }

        .logout-btn:hover {
            transform: scale(1.05);
        }

    /* Animation */

    @@keyframes slideIn {

        from {
            transform: translateX(-100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

</style>


@code {

    void Logout()
    {
        auth.Logout();
        nav.NavigateTo("/login");
    }

}