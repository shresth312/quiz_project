@page "/dashboard"
@using quiz_project.Services
@inject AuthService auth
@inject quiz_project.Services.UserSession session
@inject NavigationManager nav

@if (string.IsNullOrEmpty(auth.CurrentUser))
{
    <h4>Please login first</h4>
}
else
{
    <div class="dashboard-container">

        <h1 class="welcome-text">
            Welcome @session.Username 👋
        </h1>

        <div class="intro-box">

            <h2>📚 Improve Your Financial Literacy</h2>

            <p>
                Financial literacy helps you make smarter decisions
                about saving, investing, budgeting and spending.
                Start learning today through interactive quizzes.
            </p>

        </div>


        <div class="category-grid">

            <div class="category-card savings"
                 @onclick='() => StartQuiz("Savings")'>

                💰 Savings
                <span>Learn how to build strong saving habits</span>

            </div>


            <div class="category-card investing"
                 @onclick='() => StartQuiz("Investing")'>

                📈 Investing
                <span>Grow your money with smart investments</span>

            </div>


            <div class="category-card trading"
                 @onclick='() => StartQuiz("Trading")'>

                📊 Trading
                <span>Understand stock market basics</span>

            </div>


            <div class="category-card spending"
                 @onclick='() => StartQuiz("Spending")'>

                🛒 Spending
                <span>Control expenses and budget wisely</span>

            </div>

        </div>


        <div class="importance-box">

            <h2>Why Financial Literacy Matters 💡</h2>

            <ul>

                <li>✔ Helps manage money efficiently</li>

                <li>✔ Builds wealth over time</li>

                <li>✔ Reduces financial stress</li>

                <li>✔ Improves investment decisions</li>

            </ul>

        </div>

    </div>
}

@code {

    void StartQuiz(string category)
    {
        nav.NavigateTo($"/quiz/{category}");
    }


}